{
    "name": "rak200/http-input",
    "description": "Strict, typed reading and validation of HTTP request data (GET/POST/cookies/server/JSON bodies) for PHP 8.4+. A constraint chain with three terminals — throw, fall back, or collect — over any source array. Built on rak200/utils.",
    "version": "0.2.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["input", "request", "http", "get", "post", "validation", "json", "php84"],
    "homepage": "https://github.com/rak200/http-input",
    "authors": [
        {
            "name": "rak200",
            "email": "rak.ricardo@windowslive.com",
            "homepage": "https://github.com/rak200"
        }
    ],
    "support": {
        "issues": "https://github.com/rak200/http-input/issues",
        "source": "https://github.com/rak200/http-input"
    },
    "require": {
        "php": "^8.4",
        "rak200/utils": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../utils"
        }
    ],
    "autoload": {
        "psr-4": {
            "Rak200\\HttpInput\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rak200\\HttpInput\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}
