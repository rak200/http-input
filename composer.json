{
    "name": "rak200/http-input",
    "description": "Typed, safe reading of HTTP request data (GET/POST/cookies/server) for PHP 8.4+. Pure typed accessors over any source array plus thin superglobal shortcuts. Built on rak200/utils.",
    "version": "0.1.1",
    "type": "library",
    "license": "MIT",
    "keywords": ["input", "request", "http", "get", "post", "sanitize", "php84"],
    "homepage": "https://github.com/rak200/http-input",
    "authors": [
        {
            "name": "rak200",
            "email": "rak.ricardo@windowslive.com",
            "homepage": "https://github.com/rak200"
        }
    ],
    "support": {
        "issues": "https://github.com/rak200/http-input/issues",
        "source": "https://github.com/rak200/http-input"
    },
    "require": {
        "php": "^8.4",
        "rak200/utils": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../utils"
        }
    ],
    "autoload": {
        "psr-4": {
            "Rak200\\HttpInput\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rak200\\HttpInput\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    }
}
